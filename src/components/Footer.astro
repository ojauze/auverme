---
import { siteConfig, navLinks } from "../data/config";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">

    <!-- Colonne 1 : identité -->
    <div class="footer-brand">
      <a href="/" class="footer-logo">{siteConfig.shortName}</a>
      <p class="footer-tagline">{siteConfig.description}</p>
    </div>

    <!-- Colonne 2 : navigation -->
    <nav class="footer-nav" aria-label="Navigation footer">
      <p class="footer-heading">Pages</p>
      <ul role="list">
        {navLinks.map(link => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <!-- Colonne 3 : contact -->
    <div class="footer-contact">
      <p class="footer-heading">Contact</p>
      <ul role="list">
        <li>📍 {siteConfig.contact.city}, {siteConfig.contact.region}</li>
        <li>💻 Séances en visioconférence</li>
        {siteConfig.contact.email && (
          <li>
            ✉️ <a href={`mailto:${siteConfig.contact.email}`}>{siteConfig.contact.email}</a>
          </li>
        )}
        {siteConfig.contact.phone && (
          <li>
            📞 <a href={`tel:${siteConfig.contact.phone}`}>{siteConfig.contact.phone}</a>
          </li>
        )}
      </ul>
      <a href="/contact" class="footer-cta">Prendre rendez-vous →</a>
    </div>

  </div>

  <!-- Barre copyright -->
  <div class="footer-bottom">
    <p>
      &copy; {year} {siteConfig.name}.
      Tous droits réservés.
    </p>
    <p class="footer-legal">
      Orthopédagogie à {siteConfig.contact.city} &amp; en visio
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    background: var(--color-warm-900, #1a1a16);
    color: var(--color-warm-300, #d4d4ce);
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 2rem 2rem;
    display: grid;
    grid-template-columns: 2fr 1fr 1.5fr;
    gap: 3rem;
  }

  /* ---- Brand ---- */
  .footer-logo {
    display: inline-block;
    font-family: var(--font-display, 'Fredoka', sans-serif);
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-brand-300, #edc47f);
    text-decoration: none;
    margin-bottom: 0.75rem;
  }

  .footer-logo:hover {
    color: var(--color-brand-200, #f5ddb0);
  }

  .footer-tagline {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-warm-400, #a8a89e);
    margin: 0;
    max-width: 28ch;
  }

  /* ---- Nav & Contact columns ---- */
  .footer-heading {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-warm-400, #a8a89e);
    margin: 0 0 1rem;
  }

  .footer-nav ul,
  .footer-contact ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-nav a,
  .footer-contact a {
    color: var(--color-warm-300, #d4d4ce);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .footer-nav a:hover,
  .footer-contact a:hover {
    color: var(--color-brand-300, #edc47f);
  }

  .footer-contact li {
    font-size: 0.9rem;
    display: flex;
    gap: 0.5rem;
    align-items: baseline;
  }

  /* ---- CTA ---- */
  .footer-cta {
    display: inline-flex;
    margin-top: 1.25rem;
    padding: 0.5rem 1.25rem;
    background: var(--color-brand-500, #d4853a);
    color: #fff !important;
    border-radius: var(--radius-btn, 9999px);
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s;
  }

  .footer-cta:hover {
    background: var(--color-brand-400, #e3a34e) !important;
  }

  /* ---- Bottom bar ---- */
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    max-width: 1100px;
    margin: 0 auto;
    padding: 1.25rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-bottom p {
    margin: 0;
    font-size: 0.8rem;
    color: var(--color-warm-500, #7a7a70);
  }

  .footer-legal {
    font-style: italic;
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 2rem 1.5rem 1.5rem;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      padding: 1rem 1.5rem;
    }
  }
</style>
