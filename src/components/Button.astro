---
interface Props {
  /** Rendu comme <a> si href fourni, sinon <button> */
  href?: string;
  /** Variante visuelle */
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  /** Taille */
  size?: 'sm' | 'md' | 'lg';
  /** Type HTML (button uniquement) */
  type?: 'button' | 'submit' | 'reset';
  /** Ouvrir dans un nouvel onglet */
  external?: boolean;
  /** Désactiver le bouton */
  disabled?: boolean;
  class?: string;
  [key: string]: unknown;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  type = 'button',
  external = false,
  disabled = false,
  class: className,
  ...rest
} = Astro.props;

const Tag = href ? 'a' : 'button';
const externalProps = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

{href ? (
  <a
    href={href}
    class:list={["btn", `btn--${variant}`, `btn--${size}`, { "btn--disabled": disabled }, className]}
    aria-disabled={disabled ? "true" : undefined}
    {...externalProps}
    {...rest}
  >
    <slot />
  </a>
) : (
  <button
    type={type}
    class:list={["btn", `btn--${variant}`, `btn--${size}`, className]}
    disabled={disabled}
    {...rest}
  >
    <slot />
  </button>
)}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-weight: 600;
    text-decoration: none;
    border: 2px solid transparent;
    border-radius: var(--radius-btn, 9999px);
    cursor: pointer;
    transition: background 0.2s, color 0.2s, border-color 0.2s, transform 0.1s, box-shadow 0.2s;
    white-space: nowrap;
    line-height: 1;
  }

  .btn:hover  { transform: translateY(-1px); }
  .btn:active { transform: translateY(0); }

  /* ---- Sizes ---- */
  .btn--sm { padding: 0.4rem 1rem;  font-size: 0.8125rem; }
  .btn--md { padding: 0.6rem 1.5rem; font-size: 0.9375rem; }
  .btn--lg { padding: 0.8rem 2rem;   font-size: 1.0625rem; }

  /* ---- Variants ---- */
  .btn--primary {
    background: var(--color-brand-500, #d4853a);
    color: #fff;
  }
  .btn--primary:hover {
    background: var(--color-brand-600, #b8692b);
    color: #fff;
    box-shadow: 0 4px 12px rgba(212, 133, 58, 0.35);
  }

  .btn--secondary {
    background: var(--color-accent-500, #468d6a);
    color: #fff;
  }
  .btn--secondary:hover {
    background: var(--color-accent-600, #357156);
    color: #fff;
    box-shadow: 0 4px 12px rgba(70, 141, 106, 0.3);
  }

  .btn--outline {
    background: transparent;
    color: var(--color-brand-600, #b8692b);
    border-color: var(--color-brand-400, #e3a34e);
  }
  .btn--outline:hover {
    background: var(--color-brand-50, #fdf8f0);
    border-color: var(--color-brand-500, #d4853a);
    color: var(--color-brand-700, #944f20);
  }

  .btn--ghost {
    background: transparent;
    color: var(--color-warm-700, #4a4a42);
    border-color: transparent;
  }
  .btn--ghost:hover {
    background: var(--color-warm-100, #f5f5f3);
    color: var(--color-warm-900, #1a1a16);
  }

  /* ---- Disabled ---- */
  .btn--disabled,
  .btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
    transform: none;
    pointer-events: none;
  }
</style>
