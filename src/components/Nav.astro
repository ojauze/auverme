---
import { navLinks, siteConfig } from "../data/config";

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <nav class="nav" aria-label="Navigation principale">
    <!-- Logo -->
    <a href="/" class="nav-logo" aria-label={`${siteConfig.shortName} — accueil`}>
      {siteConfig.shortName}
    </a>

    <!-- Liens desktop -->
    <ul class="nav-links" role="list">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class:list={["nav-link", { active: currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href)) }]}
            aria-current={currentPath === link.href ? "page" : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA desktop -->
    <a href="/contact" class="nav-cta" aria-label="Prendre rendez-vous">
      Prendre RDV
    </a>

    <!-- Bouton hamburger -->
    <button
      class="hamburger"
      id="hamburger"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span><span></span><span></span>
    </button>
  </nav>
</header>

<!-- Menu mobile -->
<div class="mobile-menu" id="mobile-menu" aria-hidden="true" role="dialog" aria-label="Menu de navigation">
  <ul role="list">
    {navLinks.map(link => (
      <li>
        <a
          href={link.href}
          class:list={["mobile-link", { active: currentPath === link.href }]}
          aria-current={currentPath === link.href ? "page" : undefined}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
  <a href="/contact" class="mobile-cta">Prendre RDV</a>
</div>

<script>
  const hamburger = document.getElementById("hamburger")!;
  const mobileMenu = document.getElementById("mobile-menu")!;

  hamburger.addEventListener("click", () => {
    const isOpen = mobileMenu.classList.toggle("open");
    hamburger.classList.toggle("is-open", isOpen);
    hamburger.setAttribute("aria-expanded", String(isOpen));
    mobileMenu.setAttribute("aria-hidden", String(!isOpen));
    document.body.style.overflow = isOpen ? "hidden" : "";
  });

  mobileMenu.querySelectorAll(".mobile-link, .mobile-cta").forEach(link => {
    link.addEventListener("click", () => {
      mobileMenu.classList.remove("open");
      hamburger.classList.remove("is-open");
      hamburger.setAttribute("aria-expanded", "false");
      mobileMenu.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
    });
  });
</script>

<style>
  /* ---- Header ---- */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 200;
    height: var(--header-height, 4rem);
  }

  .nav {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;

    /* Glassmorphism */
    background: rgba(253, 248, 240, 0.75);
    backdrop-filter: blur(12px) saturate(160%);
    -webkit-backdrop-filter: blur(12px) saturate(160%);
    border-bottom: 1px solid rgba(212, 133, 58, 0.12);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.04);
  }

  /* ---- Logo ---- */
  .nav-logo {
    font-family: var(--font-display, 'Fredoka', sans-serif);
    font-size: 1.5rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--color-brand-600, #b8692b);
    letter-spacing: 0.01em;
    transition: color 0.2s;
  }

  .nav-logo:hover {
    color: var(--color-brand-700, #944f20);
  }

  /* ---- Links desktop ---- */
  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    text-decoration: none;
    color: var(--color-warm-600, #5f5f56);
    font-size: 0.95rem;
    font-weight: 500;
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }

  .nav-link:hover {
    color: var(--color-warm-900, #1a1a16);
    border-bottom-color: var(--color-brand-400, #e3a34e);
  }

  .nav-link.active {
    color: var(--color-brand-600, #b8692b);
    border-bottom-color: var(--color-brand-500, #d4853a);
  }

  /* ---- CTA desktop ---- */
  .nav-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 1.1rem;
    background: var(--color-brand-500, #d4853a);
    color: #fff;
    border-radius: var(--radius-btn, 9999px);
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, transform 0.1s;
    white-space: nowrap;
  }

  .nav-cta:hover {
    background: var(--color-brand-600, #b8692b);
    color: #fff;
    transform: translateY(-1px);
  }

  /* ---- Hamburger ---- */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    border-radius: 6px;
  }

  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-warm-800, #2e2e28);
    border-radius: 2px;
    transition: transform 0.25s, opacity 0.2s;
    transform-origin: center;
  }

  .hamburger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.is-open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ---- Mobile menu ---- */
  .mobile-menu {
    display: none;
    position: fixed;
    inset: var(--header-height, 4rem) 0 0;
    background: var(--color-brand-50, #fdf8f0);
    z-index: 199;
    padding: 2rem;
    overflow-y: auto;
    flex-direction: column;
    gap: 0.5rem;
  }

  .mobile-menu.open {
    display: flex;
  }

  .mobile-menu ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .mobile-link {
    display: block;
    font-size: 1.25rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--color-warm-700, #4a4a42);
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-warm-200, #e8e8e4);
    transition: color 0.2s;
  }

  .mobile-link:hover,
  .mobile-link.active {
    color: var(--color-brand-600, #b8692b);
  }

  .mobile-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 2rem;
    padding: 0.75rem 2rem;
    background: var(--color-brand-500, #d4853a);
    color: #fff;
    border-radius: var(--radius-btn, 9999px);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s;
  }

  .mobile-cta:hover {
    background: var(--color-brand-600, #b8692b);
    color: #fff;
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .nav-links,
    .nav-cta {
      display: none;
    }

    .hamburger {
      display: flex;
    }
  }
</style>
