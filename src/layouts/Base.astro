---
import TwSizeIndicator from "@/components/TwSizeIndicator.astro";
import config from "@/config/config.json";
import { plainify } from "@/lib/utils/textConverter";
import Footer from "@/partials/Footer.astro";
import Header from "@/partials/Header.astro";
import "@/styles/main.css";
import { ClientRouter } from "astro:transitions";

export interface Props {
  title?: string;
  meta_title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  canonical?: string;
}

const { title, meta_title, description, image, noindex, canonical } = Astro.props;

const pageTitle = plainify(meta_title ? meta_title : title ? title : config.site.title);
const pageTitleFull = (meta_title || title) ? `${pageTitle} — ${config.site.title}` : pageTitle;
const pageDescription = plainify(description ? description : config.metadata.meta_description);
const pageImage = `${config.site.base_url}${image ? image : config.metadata.meta_image}`;
const canonicalURL = canonical ?? `${config.site.base_url}${Astro.url.pathname}`;

const schema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Auver'me Orthopédagogie",
  "url": config.site.base_url,
  "description": config.metadata.meta_description,
  "email": "contact.auverme@gmail.com",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Royat",
    "postalCode": "63130",
    "addressRegion": "Puy-de-Dôme",
    "addressCountry": "FR"
  },
  "areaServed": [
    { "@type": "City", "name": "Royat" },
    { "@type": "City", "name": "Clermont-Ferrand" },
    { "@type": "Country", "name": "France" }
  ],
  "founder": {
    "@type": "Person",
    "name": "Anne Jauze",
    "jobTitle": "Orthopédagogue"
  },
  "sameAs": [
    "https://www.instagram.com/auvermeorthopedagogie/"
  ]
};
---

<!doctype html>
<html lang="fr">
  <head>
    <!-- favicon -->
    <link rel="shortcut icon" href={config.site.favicon} />
    <!-- theme meta -->
    <meta name="theme-color" content="#fdf8f0" />
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />

    <!-- responsive meta -->
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />

    <!-- Google Fonts — preconnect then stylesheet (non render-blocking) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600&family=Fredoka:wght@500;600&display=swap" />

    <!-- title -->
    <title>{pageTitleFull}</title>

    <!-- canonical url -->
    <link rel="canonical" href={canonicalURL} />

    <!-- noindex robots -->
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- meta-description -->
    <meta name="description" content={pageDescription} />

    <ClientRouter />

    <!-- author -->
    <meta name="author" content={config.metadata.meta_author} />

    <!-- og -->
    <meta property="og:title" content={pageTitleFull} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={pageImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="fr_FR" />

    <!-- twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitleFull} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={pageImage} />

    <!-- schema.org LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body class="flex flex-col min-h-screen">
    <Header />
    <main class="grow" id="main-content">
      <slot />
    </main>
    <Footer />
    <TwSizeIndicator />
  </body>
</html>
