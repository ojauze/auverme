---
import Nav from "../components/Nav.astro";
import "../styles/global.css";
import { siteConfig } from "../data/config";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title,
  description = siteConfig.description,
  ogImage = siteConfig.seo.ogImage,
  canonical = new URL(Astro.url.pathname, siteConfig.url).href,
} = Astro.props;

const fullTitle = title === siteConfig.shortName
  ? siteConfig.name
  : `${title} — ${siteConfig.shortName}`;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:locale"      content={siteConfig.locale} />
    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonical} />
    <meta property="og:site_name"   content={siteConfig.name} />
    {ogImage && <meta property="og:image" content={new URL(ogImage, siteConfig.url).href} />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; {new Date().getFullYear()} {siteConfig.shortName} — Orthopédagogie à {siteConfig.contact.city}</p>
    </footer>
  </body>
</html>

<style>
  :root {
    --header-height: 4rem;
  }

  main {
    max-width: 860px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    padding-top: calc(var(--header-height) + 2rem);
  }

  footer {
    text-align: center;
    padding: 2rem;
    color: var(--color-warm-500);
    font-size: 0.875rem;
    border-top: 1px solid var(--color-warm-200);
  }
</style>
