---
import { getCollection } from "astro:content";
import { format } from "date-fns";
import { fr } from "date-fns/locale";
import { CATEGORY_COLORS, DEFAULT_CATEGORY_COLOR } from "@/lib/categoryColors";

const today = new Date();
today.setHours(0, 0, 0, 0);

// --- Événements à venir ---
const allEvents = await getCollection("events", ({ data }) => !data.draft);
const upcomingEvents = allEvents
  .filter((e) => e.data.date >= today)
  .map((e) => ({
    type: "event" as const,
    date: e.data.date,
    title: e.data.title,
    category: e.data.category,
    time: e.data.time,
    location: e.data.location,
    description: e.data.description,
    image: e.data.image as string | undefined,
    link: e.data.link,
  }));

// --- Posts Instagram (collection manuelle) ---
const allInstagram = await getCollection("instagram", ({ data }) => !data.draft);
const recentInstagram = allInstagram.map((p) => ({
  type: "instagram" as const,
  date: p.data.date,
  title: p.data.title ?? "Post Instagram",
  category: undefined as string | undefined,
  time: undefined as string | undefined,
  location: undefined as string | undefined,
  description: p.data.description,
  image: p.data.image,
  link: p.data.link,
}));

// --- Fusion : événements à venir (triés ASC) puis posts récents (triés DESC) ---
// Priorité aux événements à venir ; les posts Instagram comblent les slots restants.
const sortedEvents = upcomingEvents.sort(
  (a, b) => a.date.getTime() - b.date.getTime()
);
const sortedInstagram = recentInstagram.sort(
  (a, b) => b.date.getTime() - a.date.getTime()
);
const items = [...sortedEvents, ...sortedInstagram].slice(0, 3);

const INSTAGRAM_COLOR = "bg-pink-100 text-pink-700 dark:bg-pink-900/30 dark:text-pink-300";
---

{items.length > 0 && (
  <section class="section-sm">
    <div class="container">
      <!-- Header -->
      <div class="row justify-center mb-10">
        <div class="text-center lg:col-6">
          <h2 class="mb-3">Actualités</h2>
          <p class="text-text-light dark:text-darkmode-text-light">
            News, Ateliers, conférences et permanences à venir.
          </p>
        </div>
      </div>

      <!-- Cards -->
      <div class="row gy-4 justify-center">
        {items.map((item) => (
          <div class="md:col-6 lg:col-4">
            <div class="h-full rounded-xl border border-border bg-body shadow-sm dark:border-darkmode-border dark:bg-darkmode-body flex flex-col overflow-hidden">

              {/* Image en en-tête (événement ou Instagram) */}
              {item.image && (
                <div class={`overflow-hidden bg-light dark:bg-darkmode-light ${item.type === "instagram" ? "aspect-square" : "aspect-video"}`}>
                  <img
                    src={item.image}
                    alt={item.title}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
              )}

              <div class="p-6 flex flex-col gap-3 flex-1">
                {/* Badge */}
                <span class={`inline-block self-start rounded-full px-3 py-0.5 text-xs font-semibold ${
                  item.type === "instagram"
                    ? INSTAGRAM_COLOR
                    : (CATEGORY_COLORS[item.category ?? ""] ?? DEFAULT_CATEGORY_COLOR)
                }`}>
                  {item.type === "instagram" ? "Instagram" : item.category}
                </span>

                {/* Date */}
                <p class="text-sm font-bold text-primary">
                  {format(item.date, "EEEE d MMMM yyyy", { locale: fr })}
                  {item.time && (
                    <span class="font-normal text-text-light dark:text-darkmode-text-light">
                      {" · "}{item.time}
                    </span>
                  )}
                </p>

                {/* Titre */}
                <h3 class="h5 leading-snug">{item.title}</h3>

                {/* Lieu (événements) */}
                {item.location && (
                  <p class="text-sm text-text-light dark:text-darkmode-text-light">
                    📍 {item.location}
                  </p>
                )}

                {/* Description */}
                {item.description && (
                  <p class="text-sm text-text dark:text-darkmode-text line-clamp-2 flex-1">
                    {item.description}
                  </p>
                )}

                {/* CTA */}
                {item.link && (
                  <a
                    href={item.link}
                    class="btn btn-outline-primary btn-sm self-start mt-auto"
                    {...(item.type === "instagram"
                      ? { target: "_blank", rel: "noopener noreferrer" }
                      : {})}
                  >
                    {item.type === "instagram" ? "Voir sur Instagram" : "En savoir plus"}
                  </a>
                )}
              </div>

            </div>
          </div>
        ))}
      </div>

      <!-- Lien vers la page complète -->
      <div class="row mt-10">
        <div class="text-center">
          <a href="/actualites" class="btn btn-primary">
            Voir toutes les actualités
          </a>
        </div>
      </div>
    </div>
  </section>
)}
