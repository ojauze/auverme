---
const GA_ID = "G-XK77YW9M71";
---

<!-- Cookie consent banner -->
<div
  id="cookie-banner"
  role="dialog"
  aria-label="Consentement aux cookies"
  aria-modal="false"
  class="fixed bottom-0 left-0 right-0 z-50 hidden border-t border-border bg-white px-4 py-4 shadow-lg dark:border-darkmode-border dark:bg-darkmode-body"
>
  <div class="container">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-sm text-text dark:text-darkmode-text">
        Ce site utilise Google Analytics pour mesurer son audience.
        <a
          href="/politique-confidentialite"
          class="text-primary underline hover:no-underline"
        >En savoir plus</a>.
      </p>
      <div class="flex shrink-0 gap-2">
        <button
          id="cookie-decline"
          class="rounded border border-border px-4 py-2 text-sm font-medium text-text transition-colors hover:bg-light dark:border-darkmode-border dark:text-darkmode-text dark:hover:bg-darkmode-light"
        >
          Refuser
        </button>
        <button
          id="cookie-accept"
          class="btn btn-primary px-4 py-2 text-sm"
        >
          Accepter
        </button>
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ GA_ID }}>
  const CONSENT_KEY = "auverme_cookie_consent";

  function loadGA() {
    if (document.getElementById("ga-script")) return;
    const s = document.createElement("script");
    s.id = "ga-script";
    s.async = true;
    s.src = "https://www.googletagmanager.com/gtag/js?id=" + GA_ID;
    document.head.appendChild(s);
    window.dataLayer = window.dataLayer || [];
    function gtag() { dataLayer.push(arguments); }
    window.gtag = gtag;
    gtag("js", new Date());
    gtag("config", GA_ID);
  }

  function initBanner() {
    const banner = document.getElementById("cookie-banner");
    const acceptBtn = document.getElementById("cookie-accept");
    const declineBtn = document.getElementById("cookie-decline");
    if (!banner || !acceptBtn || !declineBtn) return;

    const consent = localStorage.getItem(CONSENT_KEY);

    if (consent === "accepted") {
      loadGA();
      return;
    }
    if (consent === "declined") {
      return;
    }

    // No choice yet — show banner
    banner.classList.remove("hidden");

    acceptBtn.addEventListener("click", () => {
      localStorage.setItem(CONSENT_KEY, "accepted");
      banner.classList.add("hidden");
      loadGA();
    });

    declineBtn.addEventListener("click", () => {
      localStorage.setItem(CONSENT_KEY, "declined");
      banner.classList.add("hidden");
    });
  }

  // Run on first load and after each client-side navigation (View Transitions)
  document.addEventListener("astro:page-load", initBanner);
</script>
