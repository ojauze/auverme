---
import Base from "@/layouts/Base.astro";
import CallToAction from "@/partials/CallToAction.astro";
import EventsCalendar from "@/components/EventsCalendar";
import { getListPage } from "@/lib/contentParser.astro";
import { getCollection } from "astro:content";
import { format } from "date-fns";
import type { CalendarEvent } from "@/components/EventsCalendar";

const call_to_action = await getListPage("ctaSection", "call-to-action");

const today = new Date();
today.setHours(0, 0, 0, 0);

const allEvents = await getCollection("events", ({ data }) => !data.draft);
const sorted = allEvents.sort(
  (a, b) => a.data.date.getTime() - b.data.date.getTime()
);
const upcoming = sorted.filter((e) => e.data.date >= today);
const past = sorted
  .filter((e) => e.data.date < today)
  .reverse(); // most recent past first

// Convert to ScheduleX format: "YYYY-MM-DD"
const calendarEvents: CalendarEvent[] = allEvents.map((e) => ({
  id:          e.id,
  title:       e.data.title,
  start:       format(e.data.date, "yyyy-MM-dd"),
  end:         format(e.data.end_date ?? e.data.date, "yyyy-MM-dd"),
  description: e.data.description,
  location:    e.data.location,
  category:    e.data.category,
}));

// Default calendar date = nearest upcoming event, or today
const defaultDate =
  upcoming.length > 0
    ? format(upcoming[0].data.date, "yyyy-MM-dd")
    : format(today, "yyyy-MM-dd");
---

<Base
  title="Événements"
  meta_title="Événements — Auverme Orthopédagogie"
  description="Ateliers, conférences et permanences organisés par Auverme, orthopédagogue à Royat."
>
  <!-- Page header -->
  <section class="section pt-14">
    <div class="container">
      <div class="row justify-center text-center">
        <div class="lg:col-7 md:col-9">
          <p class="mb-3 text-sm font-bold uppercase tracking-widest text-primary">
            Agenda
          </p>
          <h1 class="mb-4">Événements</h1>
          <p class="text-text-light dark:text-darkmode-text-light">
            Ateliers, conférences et permanences — à Royat ou en visioconférence.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ScheduleX interactive calendar -->
  <section class="section-sm">
    <div class="container">
      <EventsCalendar
        events={calendarEvents}
        defaultDate={defaultDate}
        client:load
      />
    </div>
  </section>

  <!-- À venir — timeline -->
  {upcoming.length > 0 && (
    <section class="section-sm bg-gradient">
      <div class="container">
        <div class="row justify-center">
          <div class="lg:col-8 md:col-10">
            <h2 class="mb-10">À venir</h2>
            <ol class="space-y-0">
              {upcoming.map((event, i) => (
                <li class="flex gap-6 pb-8 relative">
                  {i < upcoming.length - 1 && (
                    <div class="absolute left-[2.25rem] top-10 bottom-0 w-px bg-border dark:bg-darkmode-border" />
                  )}
                  <!-- Date column -->
                  <div class="flex-shrink-0 w-18 text-right">
                    <span class="text-sm font-bold text-primary">
                      {format(event.data.date, "dd/MM")}
                    </span>
                    <br />
                    <span class="text-xs text-text-light dark:text-darkmode-text-light">
                      {format(event.data.date, "yyyy")}
                    </span>
                  </div>
                  <!-- Dot -->
                  <div class="relative flex-shrink-0 mt-0.5">
                    <div class="w-4 h-4 rounded-full bg-primary ring-2 ring-body dark:ring-darkmode-body ring-offset-2" />
                  </div>
                  <!-- Content -->
                  <div class="flex-1">
                    {event.data.category && (
                      <span class="text-xs font-semibold text-text-light dark:text-darkmode-text-light uppercase tracking-wide">
                        {event.data.category}
                      </span>
                    )}
                    <h3 class="h5 mt-0.5 mb-1">{event.data.title}</h3>
                    {(event.data.location || event.data.time) && (
                      <p class="text-sm text-text-light dark:text-darkmode-text-light mb-1">
                        {event.data.time && <span>{event.data.time}</span>}
                        {event.data.time && event.data.location && <span> · </span>}
                        {event.data.location && <span>📍 {event.data.location}</span>}
                      </p>
                    )}
                    {event.data.description && (
                      <p class="text-sm text-text dark:text-darkmode-text">
                        {event.data.description}
                      </p>
                    )}
                    {event.data.link && (
                      <a href={event.data.link} class="btn btn-outline-primary btn-sm mt-3 inline-block">
                        En savoir plus
                      </a>
                    )}
                  </div>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Passés -->
  {past.length > 0 && (
    <section class="section-sm">
      <div class="container">
        <div class="row justify-center">
          <div class="lg:col-8 md:col-10">
            <h2 class="mb-8 text-text-light dark:text-darkmode-text-light">Événements passés</h2>
            <ul class="space-y-4">
              {past.map((event) => (
                <li class="flex items-start gap-4 opacity-60">
                  <span class="flex-shrink-0 text-sm font-semibold text-text-light dark:text-darkmode-text-light w-14 text-right pt-0.5">
                    {format(event.data.date, "dd/MM/yy")}
                  </span>
                  <div>
                    {event.data.category && (
                      <span class="text-xs text-text-light dark:text-darkmode-text-light uppercase tracking-wide">
                        {event.data.category} · {" "}
                      </span>
                    )}
                    <span class="font-medium text-text dark:text-darkmode-text">
                      {event.data.title}
                    </span>
                    {event.data.location && (
                      <span class="text-xs text-text-light dark:text-darkmode-text-light ml-2">
                        📍 {event.data.location}
                      </span>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  )}

  <CallToAction call_to_action={call_to_action} />
</Base>
