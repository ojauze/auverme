---
import Base from "@/layouts/Base.astro";
import CallToAction from "@/partials/CallToAction.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import { getCollection } from "astro:content";

const call_to_action = await getListPage("ctaSection", "call-to-action");

const allTemoignages = await getCollection("temoignages", ({ data }) => !data.draft);
const testimonials = allTemoignages.sort((a, b) => a.data.order - b.data.order);

const audiences = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path d="M17 20H7m10 0a3 3 0 013 3H4a3 3 0 013-3m10 0V7a4 4 0 00-4-4H9a4 4 0 00-4 4v13"/><circle cx="12" cy="4" r="2"/></svg>`,
    label: "Enfants",
    sub: "et adolescents",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>`,
    label: "Familles",
    sub: "et parents",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path d="M12 14l9-5-9-5-9 5 9 5z"/><path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>`,
    label: "Adultes en formation",
    sub: "reconversion ou milieu pro",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`,
    label: "Seniors",
    sub: "entretien des fonctions cognitives",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
    label: "Professionnels",
    sub: "de l'éducation",
  },
];

const circleClass = (color: string) =>
  color === "primary"  ? "bg-primary text-white"
  : color === "secondary" ? "bg-[#F4A240] text-white"
  : "bg-dark dark:bg-darkmode-dark text-white";

const borderClass = (color: string) =>
  color === "primary"  ? "border-primary/20"
  : color === "secondary" ? "border-[#F4A240]/20"
  : "border-dark/10 dark:border-white/10";

const highlightClass = (color: string) =>
  color === "primary"  ? "text-primary font-semibold"
  : color === "secondary" ? "text-[#F4A240] font-semibold"
  : "font-bold";
---

<Base
  title="Témoignages — Auver'me Orthopédagogie"
  meta_title="Ils m'ont fait confiance — Témoignages"
  description="Témoignages de familles et de professionnels de l'éducation ayant fait confiance à Auver'me Orthopédagogie."
>

  <!-- En-tête -->
  <section class="section pt-14">
    <div class="container">
      <div class="row justify-center text-center">
        <div class="lg:col-8 md:col-10">
          <h1 class="mb-4">Ils m'ont fait confiance</h1>
          <p class="text-text-light dark:text-darkmode-text-light text-lg max-w-2xl mx-auto">
            Témoignages de familles et de professionnels de l'éducation.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Grille témoignages + portrait -->
  <section class="section-sm">
    <div class="container">
      <div class="row gy-6">

        <!-- Colonne témoignages (2/3) -->
        <div class="lg:col-8">
          <div class="flex flex-col gap-6">
            {testimonials.map((t) => (
              <div class={`flex gap-5 rounded-2xl border bg-body dark:bg-darkmode-body p-6 shadow-sm ${borderClass(t.data.color)}`}>
                <!-- Cercle guillemets -->
                <div class="flex-shrink-0">
                  <div class={`w-12 h-12 rounded-full flex items-center justify-center text-lg font-bold leading-none ${circleClass(t.data.color)}`}>
                    "
                  </div>
                </div>
                <!-- Contenu -->
                <div class="flex-1">
                  <div
                    class={`prose prose-p:text-text dark:prose-p:text-darkmode-text prose-p:leading-relaxed prose-strong:${highlightClass(t.data.color)} max-w-none mb-4`}
                    set:html={markdownify(t.data.quote)}
                  />
                  <div class="flex items-center gap-3 pt-3 border-t border-border dark:border-darkmode-border">
                    {t.data.type === "famille" ? (
                      <svg class="w-5 h-5 flex-shrink-0 text-text-light dark:text-darkmode-text-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 00-3-3.87"/>
                        <path d="M16 3.13a4 4 0 010 7.75"/>
                      </svg>
                    ) : (
                      <svg class="w-5 h-5 flex-shrink-0 text-text-light dark:text-darkmode-text-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <rect x="2" y="7" width="20" height="14" rx="2"/>
                        <path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/>
                      </svg>
                    )}
                    <p class="text-sm font-medium text-text-light dark:text-darkmode-text-light">{t.data.attribution}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Colonne portrait (1/3) -->
        <div class="lg:col-4">
          <div class="sticky top-24 flex flex-col items-center gap-6">
            <!-- Photo + nom -->
            <div class="rounded-2xl border border-border dark:border-darkmode-border bg-body dark:bg-darkmode-body p-8 text-center shadow-sm w-full">
              <div class="mx-auto mb-5 w-44 h-44 rounded-full overflow-hidden border-4 border-primary/20">
                <img
                  src="/images/anne-jauze.jpg"
                  alt="Anne Jauze"
                  class="w-full h-full object-cover"
                  onerror="this.src='/images/image-placeholder.png'"
                />
              </div>
              <p class="font-display text-2xl text-text dark:text-darkmode-text mb-1" style="font-style: italic;">Anne Jauze</p>
              <div class="w-8 h-0.5 bg-primary mx-auto my-3"></div>
              <p class="text-xs font-bold uppercase tracking-widest text-text-light dark:text-darkmode-text-light leading-relaxed">
                Enseignante<br />Orthopédagogue<br />Ingénieure de formation
              </p>
            </div>

            <!-- Tagline -->
            <div class="w-full rounded-2xl bg-dark dark:bg-darkmode-dark p-6 text-center text-white">
              <p class="text-base leading-snug" style="font-style: italic;">
                Chaque personne possède des ressources.<br />
                Ensemble, <span class="text-[#F4A240] font-semibold not-italic">révélons</span> leur potentiel.
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Audiences -->
  <section class="section-sm bg-gradient">
    <div class="container">
      <p class="text-center text-xs font-bold uppercase tracking-widest text-text-light dark:text-darkmode-text-light mb-8">
        Accompagnements en présentiel, en visio ou en tiers-lieu
      </p>
      <div class="row justify-center gy-4">
        {audiences.map((a) => (
          <div class="col-6 sm:col-4 md:col-2 text-center">
            <div class="flex flex-col items-center gap-2">
              <div class="w-14 h-14 rounded-full bg-primary/10 dark:bg-primary/20 flex items-center justify-center text-primary" set:html={a.icon} />
              <p class="text-xs font-semibold text-text dark:text-darkmode-text leading-tight">{a.label}</p>
              <p class="text-xs text-text-light dark:text-darkmode-text-light leading-tight">{a.sub}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CallToAction call_to_action={call_to_action} />

</Base>
