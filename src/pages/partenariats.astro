---
import Base from "@/layouts/Base.astro";
import CallToAction from "@/partials/CallToAction.astro";
import DynamicIcon from "@/helpers/DynamicIcon";
import { getListPage } from "@/lib/contentParser.astro";
import { getCollection, render } from "astro:content";

const call_to_action = await getListPage("ctaSection", "call-to-action");

const allPartenariats = await getCollection("partenariats", ({ data }) => !data.draft);
const partenariats = await Promise.all(
  allPartenariats
    .sort((a, b) => a.data.order - b.data.order)
    .map(async (p) => ({ ...p, rendered: await render(p) }))
);

const iconBg: Record<string, string> = {
  primary: "bg-primary/10 text-primary",
  green:   "bg-emerald-50 text-emerald-600 dark:bg-emerald-900/20 dark:text-emerald-400",
  orange:  "bg-orange-50 text-[#F4A240] dark:bg-orange-900/20 dark:text-orange-400",
};

const pointColor: Record<string, string> = {
  primary: "text-primary",
  green:   "text-emerald-600 dark:text-emerald-400",
  orange:  "text-[#F4A240]",
};
---

<Base
  title="Partenariats"
  meta_title="Partenariats — Orthopédagogie Royat"
  description="Découvrez les partenariats et expérimentations menés par Auver'me Orthopédagogie avec des acteurs locaux de l'éducation."
>

  <!-- En-tête -->
  <section class="section pt-14">
    <div class="container">
      <div class="row justify-center text-center">
        <div class="lg:col-8 md:col-10">
          <h1 class="mb-4">Partenariats</h1>
          <p class="text-text-light dark:text-darkmode-text-light text-lg max-w-2xl mx-auto">
            Des actions concrètes menées en collaboration avec des acteurs locaux de l'éducation et du social.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Partenariats -->
  {partenariats.map(({ data: p, rendered }, i) => {
    const { Content } = rendered;
    return (
      <section class={`section-sm ${i % 2 !== 0 ? "bg-gradient" : ""}`}>
        <div class="container">
          <div class="row items-center gy-10">

            <!-- Texte (gauche) -->
            <div class="lg:col-6">
              {p.eyebrow && (
                <p class="mb-1 text-sm font-bold uppercase tracking-widest text-primary">{p.eyebrow}</p>
              )}
              <h2 class="mb-2 font-bold">{p.title}</h2>
              <div class="mb-6 w-10 h-0.5 bg-primary"></div>

              <!-- Corps markdown -->
              <div class="mb-8 prose prose-p:text-text dark:prose-p:text-darkmode-text prose-p:leading-relaxed prose-strong:text-text dark:prose-strong:text-darkmode-text max-w-none">
                <Content />
              </div>

              <!-- Points clés -->
              {p.points.length > 0 && (
                <ul class="flex flex-col gap-4 mb-8">
                  {p.points.map((pt) => (
                    <li class="flex items-center gap-4">
                      <span class={`flex-shrink-0 w-9 h-9 rounded-lg flex items-center justify-center ${iconBg[pt.color] ?? iconBg.primary}`}>
                        <DynamicIcon icon={pt.icon} className="w-5 h-5" client:load />
                      </span>
                      <span class={`font-semibold ${pointColor[pt.color] ?? pointColor.primary}`}>
                        {pt.label}
                      </span>
                    </li>
                  ))}
                </ul>
              )}

              <!-- Citation -->
              {p.quote && (
                <div class="rounded-xl bg-dark dark:bg-darkmode-dark p-5 flex gap-4 items-start">
                  <svg class="w-5 h-5 flex-shrink-0 mt-0.5 text-white/50" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
                  </svg>
                  <p class="text-white text-sm leading-relaxed">{p.quote}</p>
                </div>
              )}
            </div>

            <!-- Image + logos (droite) -->
            <div class="lg:col-6 flex flex-col gap-6">
              {p.image && (
                <div class="rounded-2xl overflow-hidden shadow-md aspect-[4/3]">
                  <img
                    src={p.image}
                    alt={p.imageAlt ?? p.title}
                    class="w-full h-full object-cover"
                  />
                </div>
              )}

              {p.logos.length > 0 && (
                <div class="flex flex-wrap items-center justify-center gap-6">
                  <div class="rounded-xl bg-body dark:bg-darkmode-body border border-border dark:border-darkmode-border px-5 py-3 flex items-center justify-center">
                    <img src="/images/logo.png" alt="Auver'me Orthopédagogie" class="h-20 w-auto" />
                  </div>
                  {p.logos.map((logo) => (
                    <div class="rounded-xl bg-body dark:bg-darkmode-body border border-border dark:border-darkmode-border px-5 py-3 flex items-center justify-center min-w-[100px] min-h-[56px]">
                      <img src={logo.src} alt={logo.alt} class="h-20 w-auto" />
                    </div>
                  ))}
                </div>
              )}
            </div>

          </div>
        </div>
      </section>
    );
  })}

  <!-- Travaillons ensemble -->
  <section class="section-sm bg-gradient">
    <div class="container">
      <div class="row justify-center text-center">
        <div class="lg:col-7 md:col-9">
          <p class="mb-3 text-sm font-bold uppercase tracking-widest text-primary">Vous êtes un acteur de l'éducation ?</p>
          <h2 class="mb-4">Travaillons ensemble</h2>
          <p class="mb-8 text-text-light dark:text-darkmode-text-light">
            Je suis ouverte à de nouvelles collaborations : établissements scolaires, associations, collectivités, professionnels de santé. Contactez-moi pour discuter d'un projet commun.
          </p>
          <a href="/contact" class="btn btn-primary">Proposer un partenariat</a>
        </div>
      </div>
    </div>
  </section>

  <CallToAction call_to_action={call_to_action} />

</Base>
