---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/Container.astro";
import Button from "../../components/Button.astro";

export async function getStaticPaths() {
  const articles = await getCollection("actualites", ({ data }) => !data.draft);
  return articles.map(article => ({
    params: { slug: article.slug },
    props:  { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();

function formatDate(date: Date) {
  return date.toLocaleDateString("fr-FR", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<Layout
  title={article.data.title}
  description={article.data.description}
>
  <div class="article-page">
    <Container size="md">

      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="Fil d'Ariane">
        <a href="/">Accueil</a>
        <span aria-hidden="true">›</span>
        <a href="/actualites">Actualités</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">{article.data.title}</span>
      </nav>

      <!-- Header de l'article -->
      <header class="article-header">
        <div class="article-meta">
          <time datetime={article.data.date.toISOString()}>
            {formatDate(article.data.date)}
          </time>
          {article.data.tags.map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
        <h1 class="article-title">{article.data.title}</h1>
        <p class="article-desc">{article.data.description}</p>
      </header>

      <!-- Corps de l'article -->
      <div class="article-body prose">
        <Content />
      </div>

      <!-- Footer de l'article -->
      <footer class="article-footer">
        <div class="author-block">
          <span class="author-avatar" aria-hidden="true">🌿</span>
          <div>
            <p class="author-name">{article.data.author}</p>
            <p class="author-role">Orthopédagogue à Royat &amp; en visio</p>
          </div>
        </div>
        <div class="article-nav">
          <Button href="/actualites" variant="ghost" size="sm">
            ← Tous les articles
          </Button>
          <Button href="/contact" variant="primary" size="sm">
            Prendre rendez-vous
          </Button>
        </div>
      </footer>

    </Container>
  </div>
</Layout>

<style>
  .article-page {
    padding-block: 2rem 4rem;
  }

  /* ── Breadcrumb ───────────────────────────────────────────────── */
  .breadcrumb {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--color-warm-500);
    margin-bottom: 2rem;
  }

  .breadcrumb a {
    color: var(--color-brand-600);
    text-decoration: none;
  }

  .breadcrumb a:hover { text-decoration: underline; }

  .breadcrumb span[aria-current] {
    color: var(--color-warm-500);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 30ch;
  }

  /* ── Header ───────────────────────────────────────────────────── */
  .article-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-warm-200);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .article-meta time {
    font-size: 0.875rem;
    color: var(--color-warm-500);
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    background: var(--color-brand-100);
    color: var(--color-brand-700);
    border-radius: 9999px;
  }

  .article-title {
    font-family: var(--font-display, 'Fredoka', sans-serif);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 600;
    line-height: 1.2;
    margin: 0 0 0.75rem;
    color: var(--color-warm-900);
  }

  .article-desc {
    font-size: 1.1rem;
    color: var(--color-warm-600);
    line-height: 1.6;
    margin: 0;
  }

  /* ── Corps (prose) ────────────────────────────────────────────── */
  .prose {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-warm-800);
  }

  .prose :global(h2) {
    font-family: var(--font-display, 'Fredoka', sans-serif);
    font-size: 1.5rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
    color: var(--color-warm-900);
  }

  .prose :global(h3) {
    font-family: var(--font-display, 'Fredoka', sans-serif);
    font-size: 1.2rem;
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
    color: var(--color-warm-800);
  }

  .prose :global(p) {
    margin: 0 0 1.25rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.25rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.4rem;
  }

  .prose :global(strong) {
    font-weight: 700;
    color: var(--color-warm-900);
  }

  .prose :global(blockquote) {
    margin: 1.5rem 0;
    padding: 1rem 1.5rem;
    background: var(--color-brand-50);
    border-left: 4px solid var(--color-brand-400);
    border-radius: 0 0.5rem 0.5rem 0;
    color: var(--color-warm-700);
    font-style: italic;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }

  .prose :global(th),
  .prose :global(td) {
    padding: 0.6rem 1rem;
    border: 1px solid var(--color-warm-200);
    text-align: left;
  }

  .prose :global(th) {
    background: var(--color-warm-100);
    font-weight: 700;
    color: var(--color-warm-900);
  }

  .prose :global(a) {
    color: var(--color-brand-600);
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-warm-200);
    margin: 2.5rem 0;
  }

  /* ── Footer ───────────────────────────────────────────────────── */
  .article-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-warm-200);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .author-block {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .author-avatar {
    font-size: 2.5rem;
    flex-shrink: 0;
  }

  .author-name {
    font-weight: 700;
    color: var(--color-warm-900);
    margin: 0 0 0.15rem;
  }

  .author-role {
    font-size: 0.8rem;
    color: var(--color-warm-500);
    margin: 0;
  }

  .article-nav {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
</style>
