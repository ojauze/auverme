---
import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";
import Container from "../components/Container.astro";
import Button from "../components/Button.astro";
import { siteConfig } from "../data/config";

const valeurs = [
  {
    icon: "🤝",
    title: "Une relation de confiance",
    text: "Chaque personne est unique. Je prends le temps d'écouter, de comprendre et de construire un lien solide avant de proposer quoi que ce soit.",
  },
  {
    icon: "🔬",
    title: "Une approche fondée sur les preuves",
    text: "Mes pratiques s'appuient sur les recherches actuelles en sciences cognitives et en orthopédagogie pour garantir un accompagnement efficace.",
  },
  {
    icon: "🌱",
    title: "Le progrès plutôt que la performance",
    text: "Mon objectif n'est pas d'obtenir de bonnes notes mais de redonner goût à l'apprentissage et de développer une autonomie durable.",
  },
  {
    icon: "🔓",
    title: "L'accessibilité",
    text: "Séances au cabinet à Bordeaux ou en visioconférence depuis toute la France. Créneaux le soir et le samedi sur demande.",
  },
];

const formations = [
  { year: "2014", label: "Master en Sciences de l'Éducation — Université de Bordeaux" },
  { year: "2016", label: "Certificat en Orthopédagogie — Formation spécialisée" },
  { year: "2018", label: "Formation aux troubles dys et au haut potentiel" },
  { year: "2020", label: "Supervision clinique régulière — réseau de praticiens" },
  { year: "Depuis 2014", label: "10+ ans d'accompagnements individuels" },
];
---

<Layout
  title="À propos"
  description={`Découvrez le parcours et la philosophie d'${siteConfig.shortName}, orthopédagogue à Bordeaux et en visioconférence.`}
>

  <!-- ══ INTRO ══════════════════════════════════════════════════════ -->
  <Section bg="default" spacing="lg">
    <Container size="lg">
      <div class="intro-grid">
        <div class="intro-avatar" aria-hidden="true">
          <div class="avatar-circle">🌿</div>
        </div>
        <div class="intro-text">
          <p class="intro-eyebrow">À propos</p>
          <h1 class="intro-title">Bonjour, je suis {siteConfig.shortName}</h1>
          <p class="intro-lead">
            Orthopédagogue depuis plus de dix ans, j'accompagne enfants,
            adolescents et adultes qui rencontrent des difficultés d'apprentissage.
            Mon cabinet est à Bordeaux, mais je reçois aussi en visioconférence
            depuis toute la France.
          </p>
          <p>
            J'ai choisi ce métier parce que j'ai toujours été fascinée par la
            façon dont chaque cerveau apprend différemment. Il n'existe pas
            de « mauvais élève » — il existe des personnes à qui personne n'a
            encore trouvé la bonne clé.
          </p>
          <Button href="/contact" variant="primary">
            Prendre rendez-vous
          </Button>
        </div>
      </div>
    </Container>
  </Section>

  <!-- ══ PHILOSOPHIE ════════════════════════════════════════════════ -->
  <Section
    title="Mon approche"
    subtitle="Ce qui guide chaque séance, chaque bilan, chaque accompagnement."
    bg="alt"
    spacing="lg"
    id="approche"
  >
    <Container size="xl">
      <ul class="valeurs-grid" role="list">
        {valeurs.map(v => (
          <li class="valeur-card">
            <span class="valeur-icon" aria-hidden="true">{v.icon}</span>
            <h2 class="valeur-title">{v.title}</h2>
            <p class="valeur-text">{v.text}</p>
          </li>
        ))}
      </ul>
    </Container>
  </Section>

  <!-- ══ PARCOURS ═══════════════════════════════════════════════════ -->
  <Section
    title="Formation & parcours"
    subtitle="Un socle académique solide, enrichi par une pratique de terrain continue."
    bg="default"
    spacing="lg"
    id="parcours"
  >
    <Container size="md">
      <ol class="timeline" role="list">
        {formations.map(f => (
          <li class="timeline-item">
            <span class="timeline-year">{f.year}</span>
            <span class="timeline-label">{f.label}</span>
          </li>
        ))}
      </ol>
    </Container>
  </Section>

  <!-- ══ ENGAGEMENTS ════════════════════════════════════════════════ -->
  <Section bg="alt" spacing="md">
    <Container size="md">
      <div class="engagement-block">
        <p class="engagement-heading">Engagements professionnels</p>
        <ul class="engagement-list">
          <li>Membre de l'Association des Orthopédagogues de France</li>
          <li>Formation continue annuelle aux nouvelles recherches</li>
          <li>Travail en réseau avec orthophonistes, psychologues et enseignants</li>
          <li>Supervision clinique régulière pour garantir la qualité de la pratique</li>
        </ul>
      </div>
    </Container>
  </Section>

  <!-- ══ CTA ════════════════════════════════════════════════════════ -->
  <Section bg="dark" spacing="lg">
    <Container size="sm">
      <div class="final-cta">
        <h2 class="final-cta-title">Envie d'en savoir plus ?</h2>
        <p class="final-cta-sub">
          Posez-moi vos questions, je vous réponds sous {siteConfig.responseDelay}.
        </p>
        <div class="final-cta-actions">
          <Button href="/contact" variant="primary" size="lg">
            Me contacter
          </Button>
          <Button href="/articles" variant="outline" size="lg">
            Voir mes services
          </Button>
        </div>
      </div>
    </Container>
  </Section>

</Layout>

<style>
  /* ── Intro ────────────────────────────────────────────────────── */
  .intro-grid {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 4rem;
    align-items: start;
  }

  .intro-avatar {
    display: flex;
    justify-content: center;
    padding-top: 0.5rem;
  }

  .avatar-circle {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-brand-100), var(--color-accent-100));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 5rem;
    box-shadow: 0 8px 32px rgba(212,133,58,0.2);
    flex-shrink: 0;
  }

  .intro-eyebrow {
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-brand-600);
    margin: 0 0 0.75rem;
  }

  .intro-title {
    font-family: var(--font-display, 'Fredoka', sans-serif);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 600;
    margin: 0 0 1.25rem;
    color: var(--color-warm-900);
  }

  .intro-lead {
    font-size: 1.1rem;
    color: var(--color-warm-700);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .intro-text p:not(.intro-eyebrow):not(.intro-lead) {
    color: var(--color-warm-600);
    line-height: 1.7;
    margin-bottom: 1.75rem;
  }

  /* ── Valeurs ──────────────────────────────────────────────────── */
  .valeurs-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .valeur-card {
    padding: 1.75rem;
    background: #fff;
    border-radius: var(--radius-card, 1rem);
    box-shadow: var(--shadow-card);
  }

  .valeur-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 0.75rem;
  }

  .valeur-title {
    font-family: var(--font-display, 'Fredoka', sans-serif);
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    color: var(--color-warm-900);
  }

  .valeur-text {
    font-size: 0.9rem;
    color: var(--color-warm-600);
    line-height: 1.6;
    margin: 0;
  }

  /* ── Timeline ─────────────────────────────────────────────────── */
  .timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 6.5rem;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-brand-200);
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 1.5rem;
    align-items: baseline;
    padding: 1rem 0;
    position: relative;
  }

  .timeline-item::before {
    content: '';
    position: absolute;
    left: calc(6.5rem - 4px);
    top: 1.35rem;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-brand-500);
    border: 2px solid #fff;
    box-shadow: 0 0 0 2px var(--color-brand-300);
  }

  .timeline-year {
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--color-brand-600);
    text-align: right;
    padding-right: 1rem;
    line-height: 1.6;
  }

  .timeline-label {
    font-size: 0.9375rem;
    color: var(--color-warm-800);
    line-height: 1.6;
  }

  /* ── Engagements ──────────────────────────────────────────────── */
  .engagement-block {
    background: #fff;
    border-radius: var(--radius-card, 1rem);
    padding: 2rem;
    box-shadow: var(--shadow-card);
  }

  .engagement-heading {
    font-family: var(--font-display, 'Fredoka', sans-serif);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-warm-900);
    margin: 0 0 1rem;
  }

  .engagement-list {
    margin: 0;
    padding: 0 0 0 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .engagement-list li {
    font-size: 0.9375rem;
    color: var(--color-warm-700);
    line-height: 1.5;
  }

  /* ── CTA ──────────────────────────────────────────────────────── */
  .final-cta {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .final-cta-title {
    font-family: var(--font-display, 'Fredoka', sans-serif);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 600;
    color: var(--color-brand-200);
    margin: 0;
  }

  .final-cta-sub {
    color: var(--color-warm-400);
    margin: 0;
  }

  .final-cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  /* ── Responsive ───────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .intro-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .intro-avatar { display: none; }

    .timeline::before { left: 0; }
    .timeline-item { grid-template-columns: 1fr; gap: 0.25rem; padding-left: 1.5rem; }
    .timeline-item::before { left: -5px; }
    .timeline-year { text-align: left; padding-right: 0; }
  }
</style>
