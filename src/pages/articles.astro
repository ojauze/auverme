---
import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";
import Container from "../components/Container.astro";
import Button from "../components/Button.astro";
import { siteConfig } from "../data/config";

const services = [
  {
    icon: "🔍",
    title: "Bilan orthopédagogique",
    description: "Un bilan complet pour identifier précisément les forces et les difficultés. Il comprend des évaluations des compétences en lecture, écriture, mathématiques, mémoire et attention.",
    duree: "2 à 3 séances de 60 min",
    pour: "Enfants dès 6 ans, adolescents, adultes",
    resultat: "Rapport écrit détaillé + restitution orale",
  },
  {
    icon: "📚",
    title: "Accompagnement en apprentissage",
    description: "Un suivi régulier pour développer des stratégies efficaces, travailler la mémorisation, l'organisation et regagner confiance. Adapté à chaque profil.",
    duree: "Séances de 60 min — fréquence hebdomadaire recommandée",
    pour: "Primaire, collège, lycée, études supérieures",
    resultat: "Progression mesurable, autonomie renforcée",
  },
  {
    icon: "✏️",
    title: "Troubles dys (dyslexie, dysorthographie…)",
    description: "Prise en charge spécialisée des troubles spécifiques du langage et des apprentissages : dyslexie, dysorthographie, dyscalculie, dyspraxie, TDAH.",
    duree: "Suivi sur plusieurs mois",
    pour: "Tous âges — diagnostic préalable recommandé",
    resultat: "Stratégies compensatoires, outils numériques, confiance",
  },
  {
    icon: "⭐",
    title: "Haut potentiel intellectuel (HPI/HPE)",
    description: "Les enfants et adultes à haut potentiel peuvent vivre un décalage entre leurs capacités et leurs résultats scolaires. Un accompagnement adapté fait toute la différence.",
    duree: "Séances de 60 min",
    pour: "Enfants, adolescents et adultes HPI/HPE",
    resultat: "Gestion du décalage, épanouissement, méthodes adaptées",
  },
  {
    icon: "🌱",
    title: "Accompagnement adulte",
    description: "Retour aux études, reconversion, difficultés professionnelles liées à la lecture ou aux chiffres : l'orthopédagogie adulte est encore peu connue mais très efficace.",
    duree: "Bilan initial + suivi personnalisé",
    pour: "Adultes en activité ou en reconversion",
    resultat: "Stratégies adaptées, autonomie, confiance professionnelle",
  },
  {
    icon: "🖥️",
    title: "Séances en visioconférence",
    description: "Tous mes services sont disponibles en visio via une plateforme sécurisée. Même qualité d'accompagnement, zéro contrainte géographique.",
    duree: "Identique aux séances en cabinet",
    pour: "Toute la France",
    resultat: "Flexibilité, gain de temps, même efficacité",
  },
];

const pratique = [
  { label: "Durée d'une séance",    value: "60 minutes" },
  { label: "Tarif indicatif",       value: "60 – 80 € / séance" },
  { label: "Crédit d'impôt",        value: `${siteConfig.taxDeduction} via CESU (services à la personne)` },
  { label: "Prise en charge",       value: "Non remboursée Sécurité sociale — certaines mutuelles partiellement" },
  { label: "Délai de réponse",      value: `Sous ${siteConfig.responseDelay} après demande de contact` },
  { label: "Premier entretien",     value: "Gratuit — 20 min — sans engagement" },
];
---

<Layout
  title="Services"
  description={`Bilan orthopédagogique, accompagnement scolaire, troubles dys, HPI — services proposés par ${siteConfig.shortName} à Royat et en visio.`}
>

  <!-- ══ HERO ══════════════════════════════════════════════════════ -->
  <Section bg="default" spacing="lg">
    <Container size="md">
      <div class="page-hero">
        <p class="page-eyebrow">Services</p>
        <h1 class="page-title">Un accompagnement<br /><span class="accent">sur mesure</span></h1>
        <p class="page-subtitle">
          Du bilan initial au suivi régulier, chaque service est pensé pour
          répondre à un besoin précis. Découvrez comment je peux vous aider.
        </p>
      </div>
    </Container>
  </Section>

  <!-- ══ SERVICES ══════════════════════════════════════════════════ -->
  <Section bg="alt" spacing="lg" id="services">
    <Container size="xl">
      <ul class="services-list" role="list">
        {services.map((s, i) => (
          <li class="service-item" id={`service-${i}`}>
            <div class="service-icon-wrap">
              <span class="service-icon" aria-hidden="true">{s.icon}</span>
            </div>
            <div class="service-body">
              <h2 class="service-title">{s.title}</h2>
              <p class="service-desc">{s.description}</p>
              <dl class="service-meta">
                <div>
                  <dt>⏱ Durée</dt>
                  <dd>{s.duree}</dd>
                </div>
                <div>
                  <dt>👤 Pour</dt>
                  <dd>{s.pour}</dd>
                </div>
                <div>
                  <dt>✅ Résultat attendu</dt>
                  <dd>{s.resultat}</dd>
                </div>
              </dl>
            </div>
          </li>
        ))}
      </ul>
    </Container>
  </Section>

  <!-- ══ INFOS PRATIQUES ═══════════════════════════════════════════ -->
  <Section
    title="Infos pratiques"
    subtitle="Tout ce qu'il faut savoir avant de prendre rendez-vous."
    bg="default"
    spacing="lg"
    id="pratique"
  >
    <Container size="md">
      <dl class="pratique-grid">
        {pratique.map(item => (
          <div class="pratique-item">
            <dt class="pratique-label">{item.label}</dt>
            <dd class="pratique-value">{item.value}</dd>
          </div>
        ))}
      </dl>
      <p class="pratique-note">
        * Les tarifs sont donnés à titre indicatif et peuvent varier selon le type
        de prise en charge. Contactez-moi pour un devis personnalisé.
      </p>
    </Container>
  </Section>

  <!-- ══ CTA ════════════════════════════════════════════════════════ -->
  <Section bg="dark" spacing="lg">
    <Container size="sm">
      <div class="final-cta">
        <h2 class="final-cta-title">Prêt·e à commencer ?</h2>
        <p class="final-cta-sub">
          Premier entretien gratuit, sans engagement.
          Réponse sous {siteConfig.responseDelay}.
        </p>
        <div class="final-cta-actions">
          <Button href="/contact" variant="primary" size="lg">
            Prendre rendez-vous
          </Button>
          <Button href="/a-propos" variant="outline" size="lg">
            Découvrir mon parcours
          </Button>
        </div>
      </div>
    </Container>
  </Section>

</Layout>

<style>
  /* ── Page hero ────────────────────────────────────────────────── */
  .page-hero { text-align: center; }

  .page-eyebrow {
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-brand-600);
    margin: 0 0 1rem;
  }

  .page-title {
    font-family: var(--font-display, 'Fredoka', sans-serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 600;
    margin: 0 0 1.25rem;
    line-height: 1.1;
    color: var(--color-warm-900);
  }

  .accent { color: var(--color-brand-500); }

  .page-subtitle {
    font-size: 1.1rem;
    color: var(--color-warm-600);
    max-width: 52ch;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ── Services list ────────────────────────────────────────────── */
  .services-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .service-item {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    gap: 1.75rem;
    background: #fff;
    border-radius: var(--radius-card, 1rem);
    padding: 1.75rem;
    box-shadow: var(--shadow-card);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .service-item:hover {
    transform: translateX(4px);
    box-shadow: 0 6px 24px rgba(0,0,0,0.09);
  }

  .service-icon-wrap {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 0.25rem;
  }

  .service-icon { font-size: 2.25rem; }

  .service-title {
    font-family: var(--font-display, 'Fredoka', sans-serif);
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 0.6rem;
    color: var(--color-warm-900);
  }

  .service-desc {
    font-size: 0.9375rem;
    color: var(--color-warm-600);
    line-height: 1.65;
    margin: 0 0 1rem;
  }

  .service-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2rem;
    margin: 0;
  }

  .service-meta div { display: flex; gap: 0.35rem; align-items: baseline; }

  .service-meta dt {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-brand-600);
    white-space: nowrap;
  }

  .service-meta dd {
    margin: 0;
    font-size: 0.8rem;
    color: var(--color-warm-600);
  }

  /* ── Infos pratiques ──────────────────────────────────────────── */
  .pratique-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
    margin: 0 0 1.25rem;
  }

  .pratique-item {
    background: #fff;
    border-radius: 0.75rem;
    padding: 1.1rem 1.25rem;
    box-shadow: var(--shadow-card);
    border-left: 3px solid var(--color-brand-300);
  }

  .pratique-label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-brand-600);
    margin-bottom: 0.35rem;
  }

  .pratique-value {
    font-size: 0.9375rem;
    color: var(--color-warm-800);
    margin: 0;
    line-height: 1.5;
  }

  .pratique-note {
    font-size: 0.8125rem;
    color: var(--color-warm-500);
    font-style: italic;
    margin: 0;
  }

  /* ── CTA final ────────────────────────────────────────────────── */
  .final-cta {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .final-cta-title {
    font-family: var(--font-display, 'Fredoka', sans-serif);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 600;
    color: var(--color-brand-200);
    margin: 0;
  }

  .final-cta-sub { color: var(--color-warm-400); margin: 0; }

  .final-cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  /* ── Responsive ───────────────────────────────────────────────── */
  @media (max-width: 600px) {
    .service-item {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .service-icon-wrap { display: none; }
  }
</style>
