---
import Base from "@/layouts/Base.astro";
import { markdownify } from "@/lib/utils/textConverter";
import CallToAction from "@/partials/CallToAction.astro";
import { getListPage } from "@/lib/contentParser.astro";

const call_to_action = await getListPage("ctaSection", "call-to-action");

const services = [
  {
    icon: "🔍",
    title: "Bilan orthopédagogique",
    description:
      "Un bilan complet pour identifier précisément les forces et les difficultés. Il comprend des évaluations des compétences en lecture, écriture, mathématiques, mémoire et attention.",
    duree: "2 à 3 séances de 60 min",
    pour: "Enfants dès 6 ans, adolescents, adultes",
    resultat: "Rapport écrit détaillé + restitution orale",
  },
  {
    icon: "📚",
    title: "Accompagnement en apprentissage",
    description:
      "Un suivi régulier pour développer des stratégies efficaces, travailler la mémorisation, l'organisation et regagner confiance. Adapté à chaque profil.",
    duree: "Séances de 60 min — fréquence hebdomadaire recommandée",
    pour: "Primaire, collège, lycée, études supérieures",
    resultat: "Progression mesurable, autonomie renforcée",
  },
  {
    icon: "✏️",
    title: "Troubles dys (dyslexie, dysorthographie…)",
    description:
      "Prise en charge spécialisée des troubles spécifiques du langage et des apprentissages : dyslexie, dysorthographie, dyscalculie, dyspraxie, TDAH.",
    duree: "Suivi sur plusieurs mois",
    pour: "Tous âges — diagnostic préalable recommandé",
    resultat: "Stratégies compensatoires, outils numériques, confiance",
  },
  {
    icon: "⭐",
    title: "Haut potentiel intellectuel (HPI/HPE)",
    description:
      "Les enfants et adultes à haut potentiel peuvent vivre un décalage entre leurs capacités et leurs résultats scolaires. Un accompagnement adapté fait toute la différence.",
    duree: "Séances de 60 min",
    pour: "Enfants, adolescents et adultes HPI/HPE",
    resultat: "Gestion du décalage, épanouissement, méthodes adaptées",
  },
];
---

<Base
  title="Services"
  meta_title="Services — Auverme Orthopédagogie"
  description="Bilan orthopédagogique, accompagnement en apprentissage, troubles dys, haut potentiel. Séances à Royat (63) ou en visioconférence."
>
  <!-- Page Header -->
  <section class="page-header-default section pt-14">
    <div class="container">
      <div class="row justify-center text-center">
        <div class="lg:col-7 md:col-9">
          <h1 class="mb-4">Mes services</h1>
          <p class="text-text-light">
            Bilan, accompagnement, troubles dys, haut potentiel — à Royat ou en visioconférence.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="section-sm">
    <div class="container">
      <div class="row gy-4">
        {
          services.map((s) => (
            <div class="md:col-6">
              <div class="rounded-xl border border-border bg-body p-8 h-full shadow-sm dark:border-darkmode-border dark:bg-darkmode-body">
                <div class="mb-4 text-4xl">{s.icon}</div>
                <h2
                  class="h4 mb-3"
                  set:html={markdownify(s.title)}
                />
                <p class="mb-5 text-text dark:text-darkmode-text">
                  {s.description}
                </p>
                <dl class="space-y-2 text-sm">
                  <div class="flex gap-2">
                    <dt class="font-semibold text-text-dark dark:text-darkmode-text-dark min-w-20">Durée :</dt>
                    <dd class="text-text-light dark:text-darkmode-text-light">{s.duree}</dd>
                  </div>
                  <div class="flex gap-2">
                    <dt class="font-semibold text-text-dark dark:text-darkmode-text-dark min-w-20">Pour :</dt>
                    <dd class="text-text-light dark:text-darkmode-text-light">{s.pour}</dd>
                  </div>
                  <div class="flex gap-2">
                    <dt class="font-semibold text-text-dark dark:text-darkmode-text-dark min-w-20">Résultat :</dt>
                    <dd class="text-text-light dark:text-darkmode-text-light">{s.resultat}</dd>
                  </div>
                </dl>
              </div>
            </div>
          ))
        }
      </div>

      <!-- Practical info -->
      <div class="row mt-10">
        <div class="mx-auto md:col-10 lg:col-8">
          <div class="rounded-xl bg-light p-8 text-center dark:bg-darkmode-light">
            <h3 class="h4 mb-3">Informations pratiques</h3>
            <div class="row gy-4 text-sm text-text dark:text-darkmode-text">
              <div class="md:col-4">
                <p class="font-semibold text-dark dark:text-darkmode-dark mb-1">📍 Lieu</p>
                <p>Cabinet à Royat (63130)<br />Visioconférence toute la France</p>
              </div>
              <div class="md:col-4">
                <p class="font-semibold text-dark dark:text-darkmode-dark mb-1">💰 Tarifs</p>
                <p>Crédit d'impôt 50 %<br />via le dispositif CESU</p>
              </div>
              <div class="md:col-4">
                <p class="font-semibold text-dark dark:text-darkmode-dark mb-1">🕐 Horaires</p>
                <p>Sur rendez-vous<br />Soir & samedi sur demande</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CallToAction call_to_action={call_to_action} />
</Base>
