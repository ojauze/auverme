---
import Base from "@/layouts/Base.astro";
import ImageMod from "@/components/ImageMod.astro";
import CallToAction from "@/partials/CallToAction.astro";
import { markdownify } from "@/lib/utils/textConverter";
import { getListPage } from "@/lib/contentParser.astro";

const about = await getListPage("about", "-index");
const call_to_action = await getListPage("ctaSection", "call-to-action");

const { title, meta_title, description, sections = [] } = about.data;
---

<Base {title} {meta_title} {description}>

  <!-- H1 SEO -->
  <section class="section pt-14 pb-0">
    <div class="container">
      <div class="row justify-center text-center">
        <div class="lg:col-8 md:col-10">
          <h1 class="mb-4">Anne Jauze — Orthopédagogue à Royat et en visioconférence</h1>
          <p class="text-text-light dark:text-darkmode-text-light text-lg max-w-2xl mx-auto">
            Enseignante, ingénieure de formation et orthopédagogue — une approche au croisement des sciences cognitives et de l'humain.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sections alternées -->
  {sections.map((s, i) => {
    const imageLeft = i % 2 === 0;
    return (
      <section class={`section-sm ${i % 2 !== 0 ? "bg-gradient" : ""}`}>
        <div class="container">
          <div class="row items-center gy-8">

            {/* Image */}
            <div class={`md:col-4 ${!imageLeft ? "md:order-2" : ""}`}>
              <ImageMod
                src={s.image}
                alt={s.title}
                width={480}
                height={560}
                format="webp"
                class="w-full rounded-2xl object-cover shadow-sm"
              />
            </div>

            {/* Texte */}
            <div class={`md:col-8 ${!imageLeft ? "md:order-1" : ""}`}>
              <h2 class="mb-5">{s.title}</h2>
              <div class="prose prose-p:text-text dark:prose-p:text-darkmode-text prose-p:leading-relaxed max-w-none"
                set:html={markdownify(s.text, true)}
              />
            </div>

          </div>
        </div>
      </section>
    );
  })}

  <CallToAction call_to_action={call_to_action} />

</Base>
