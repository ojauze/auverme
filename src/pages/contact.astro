---
import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";
import Container from "../components/Container.astro";
import { siteConfig } from "../data/config";
---

<Layout
  title="Contact"
  description={`Contactez ${siteConfig.shortName}, orthopédagogue à ${siteConfig.contact.city}. Réponse sous ${siteConfig.responseDelay}.`}
>

  <!-- ══ HERO ══════════════════════════════════════════════════════ -->
  <Section bg="default" spacing="lg">
    <Container size="md">
      <div class="page-hero">
        <p class="page-eyebrow">Contact</p>
        <h1 class="page-title">Prenons contact</h1>
        <p class="page-subtitle">
          Première séance d'échange offerte et sans engagement.
          Je vous réponds sous <strong>{siteConfig.responseDelay}</strong>.
        </p>
      </div>
    </Container>
  </Section>

  <!-- ══ GRILLE CONTACT ════════════════════════════════════════════ -->
  <Section bg="alt" spacing="lg">
    <Container size="lg">
      <div class="contact-grid">

        <!-- Colonne infos -->
        <aside class="contact-infos">
          <div class="info-block">
            <span class="info-icon" aria-hidden="true">📍</span>
            <div>
              <strong>Cabinet</strong>
              <p>{siteConfig.contact.city}, {siteConfig.contact.region}</p>
            </div>
          </div>
          <div class="info-block">
            <span class="info-icon" aria-hidden="true">🖥️</span>
            <div>
              <strong>Visioconférence</strong>
              <p>Depuis toute la France,<br />sur plateforme sécurisée</p>
            </div>
          </div>
          <div class="info-block">
            <span class="info-icon" aria-hidden="true">⏱️</span>
            <div>
              <strong>Délai de réponse</strong>
              <p>Sous {siteConfig.responseDelay}</p>
            </div>
          </div>
          <div class="info-block">
            <span class="info-icon" aria-hidden="true">💶</span>
            <div>
              <strong>Crédit d'impôt</strong>
              <p>{siteConfig.taxDeduction} via CESU<br />(services à la personne)</p>
            </div>
          </div>
          {siteConfig.contact.email && (
            <div class="info-block">
              <span class="info-icon" aria-hidden="true">✉️</span>
              <div>
                <strong>Email direct</strong>
                <p>
                  <a href={`mailto:${siteConfig.contact.email}`}>
                    {siteConfig.contact.email}
                  </a>
                </p>
              </div>
            </div>
          )}
        </aside>

        <!-- Colonne formulaire -->
        <div class="form-wrapper">
          <form
            class="contact-form"
            id="contact-form"
            action="https://api.web3forms.com/submit"
            method="POST"
            novalidate
          >
            <!-- Clé Web3Forms (remplacée depuis config) -->
            <input type="hidden" name="access_key" value={siteConfig.contact.web3formsKey} />

            <!-- Sujet de l'email reçu dans Gmail -->
            <input type="hidden" name="subject" value={`Nouveau message — ${siteConfig.name}`} />

            <!-- Langue de la notification -->
            <input type="hidden" name="from_name" value={siteConfig.name} />

            <!-- Redirection après envoi (désactivé : on gère en JS) -->
            <input type="hidden" name="redirect" value="false" />

            <!-- Honeypot anti-spam -->
            <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" aria-hidden="true" />

            <div class="form-group">
              <label for="name">Nom et prénom <span class="required" aria-label="obligatoire">*</span></label>
              <input
                type="text"
                id="name"
                name="name"
                required
                autocomplete="name"
                placeholder="Marie Dupont"
              />
            </div>

            <div class="form-group">
              <label for="email">Email <span class="required" aria-label="obligatoire">*</span></label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                placeholder="marie@exemple.fr"
              />
            </div>

            <div class="form-group">
              <label for="phone">
                Téléphone
                <span class="optional">(optionnel)</span>
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                autocomplete="tel"
                placeholder="06 00 00 00 00"
              />
            </div>

            <div class="form-group">
              <label for="message">Message <span class="required" aria-label="obligatoire">*</span></label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                placeholder="Décrivez brièvement la situation et ce que vous recherchez…"
              ></textarea>
            </div>

            <button type="submit" class="btn-submit" id="submit-btn">
              <span class="btn-text">Envoyer le message</span>
              <span class="btn-loading" hidden aria-live="polite">Envoi en cours…</span>
            </button>
          </form>

          <!-- Confirmation -->
          <div class="alert alert--success" id="msg-success" hidden role="alert">
            <span aria-hidden="true">✅</span>
            <p>Merci ! Votre message a bien été envoyé. Je vous réponds sous {siteConfig.responseDelay}.</p>
          </div>

          <!-- Erreur -->
          <div class="alert alert--error" id="msg-error" hidden role="alert">
            <span aria-hidden="true">⚠️</span>
            <p>Une erreur est survenue. Réessayez ou écrivez directement à <a href={`mailto:${siteConfig.contact.email}`}>{siteConfig.contact.email}</a>.</p>
          </div>
        </div>

      </div>
    </Container>
  </Section>

</Layout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const btnText = submitBtn.querySelector(".btn-text") as HTMLElement;
  const btnLoading = submitBtn.querySelector(".btn-loading") as HTMLElement;
  const msgSuccess = document.getElementById("msg-success") as HTMLElement;
  const msgError = document.getElementById("msg-error") as HTMLElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    // État "chargement"
    submitBtn.disabled = true;
    btnText.hidden = true;
    btnLoading.hidden = false;
    msgSuccess.hidden = true;
    msgError.hidden = true;

    try {
      const response = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        body: new FormData(form),
        headers: { Accept: "application/json" },
      });

      const json = await response.json();

      if (response.ok && json.success) {
        form.hidden = true;
        msgSuccess.hidden = false;
      } else {
        throw new Error(json.message || "Erreur inconnue");
      }
    } catch {
      msgError.hidden = false;
      submitBtn.disabled = false;
      btnText.hidden = false;
      btnLoading.hidden = true;
    }
  });
</script>

<style>
  /* ── Hero ─────────────────────────────────────────────────────── */
  .page-hero { text-align: center; }

  .page-eyebrow {
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-brand-600);
    margin: 0 0 1rem;
  }

  .page-title {
    font-family: var(--font-display, 'Fredoka', sans-serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 600;
    margin: 0 0 1rem;
    color: var(--color-warm-900);
  }

  .page-subtitle {
    font-size: 1.05rem;
    color: var(--color-warm-600);
    margin: 0;
    line-height: 1.6;
  }

  .page-subtitle strong {
    color: var(--color-brand-600);
  }

  /* ── Grille ───────────────────────────────────────────────────── */
  .contact-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* ── Infos ────────────────────────────────────────────────────── */
  .contact-infos {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .info-block {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
  }

  .info-icon {
    font-size: 1.4rem;
    line-height: 1.3;
    flex-shrink: 0;
  }

  .info-block strong {
    display: block;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-warm-900);
    margin-bottom: 0.2rem;
  }

  .info-block p {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-warm-600);
    line-height: 1.5;
  }

  .info-block a {
    color: var(--color-brand-600);
    word-break: break-all;
  }

  /* ── Formulaire ───────────────────────────────────────────────── */
  .form-wrapper {
    background: #fff;
    border-radius: var(--radius-card, 1rem);
    padding: 2rem;
    box-shadow: var(--shadow-card);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-warm-800);
  }

  .required {
    color: var(--color-brand-500);
    margin-left: 0.15rem;
  }

  .optional {
    font-weight: 400;
    color: var(--color-warm-400);
    font-size: 0.8rem;
  }

  input,
  textarea {
    padding: 0.65rem 0.9rem;
    border: 1.5px solid var(--color-warm-200);
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    font-family: var(--font-sans, inherit);
    color: var(--color-warm-900);
    background: var(--color-brand-50);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  input::placeholder,
  textarea::placeholder {
    color: var(--color-warm-400);
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--color-brand-400);
    box-shadow: 0 0 0 3px rgba(212, 133, 58, 0.12);
    background: #fff;
  }

  textarea {
    resize: vertical;
    min-height: 130px;
  }

  /* ── Bouton ───────────────────────────────────────────────────── */
  .btn-submit {
    align-self: flex-start;
    padding: 0.7rem 1.75rem;
    background: var(--color-brand-500);
    color: #fff;
    border: none;
    border-radius: var(--radius-btn, 9999px);
    font-size: 0.9375rem;
    font-weight: 600;
    font-family: var(--font-sans, inherit);
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
  }

  .btn-submit:hover:not(:disabled) {
    background: var(--color-brand-600);
    transform: translateY(-1px);
  }

  .btn-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* ── Alertes ──────────────────────────────────────────────────── */
  .alert {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-radius: 0.75rem;
    font-size: 0.9375rem;
    line-height: 1.5;
    margin-top: 1rem;
  }

  .alert p { margin: 0; }

  .alert--success {
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    color: #166534;
  }

  .alert--error {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #991b1b;
  }

  .alert--error a {
    color: #991b1b;
    font-weight: 600;
  }

  /* ── Responsive ───────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .contact-infos {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .form-wrapper {
      padding: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .contact-infos {
      grid-template-columns: 1fr;
    }
  }
</style>
