---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact">

  <section class="contact-hero">
    <h1>Prenons contact</h1>
    <p class="subtitle">Je vous réponds sous <strong>48h</strong>.</p>
  </section>

  <section class="contact-grid">

    <!-- Colonne infos -->
    <aside class="contact-infos">
      <div class="info-block">
        <span class="icon">📍</span>
        <div>
          <strong>Zone d'intervention</strong>
          <p>Royaux, Clermont-Ferrand et agglomération<br/>France entière en visio</p>
        </div>
      </div>
      <div class="info-block">
        <span class="icon">🖥️</span>
        <div>
          <strong>Modalités</strong>
          <p>Séances en présentiel<br/>ou en visioconférence</p>
        </div>
      </div>
      <div class="info-block">
        <span class="icon">⏱️</span>
        <div>
          <strong>Délai de réponse</strong>
          <p>Je vous réponds sous 48h</p>
        </div>
      </div>
      <div class="info-block">
        <span class="icon">💶</span>
        <div>
          <strong>Avantage fiscal</strong>
          <p>Déduction fiscale de 50%<br/>(services à la personne)</p>
        </div>
      </div>
    </aside>

    <!-- Colonne formulaire -->
    <div class="contact-form-wrapper">
      <form
        class="contact-form"
        id="contact-form"
        action="https://formspree.io/f/auverme"
        method="POST"
      >
        <div class="form-group">
          <label for="nom">Nom et prénom *</label>
          <input type="text" id="nom" name="nom" required placeholder="Marie Dupont" />
        </div>

        <div class="form-group">
          <label for="email">Email *</label>
          <input type="email" id="email" name="email" required placeholder="marie@exemple.fr" />
        </div>

        <div class="form-group">
          <label for="telephone">Téléphone <span class="optional">(optionnel)</span></label>
          <input type="tel" id="telephone" name="telephone" placeholder="06 00 00 00 00" />
        </div>

        <div class="form-group">
          <label for="message">Message *</label>
          <textarea id="message" name="message" required rows="5"
            placeholder="Décrivez brièvement la situation de votre enfant et ce que vous recherchez..."></textarea>
        </div>

        <button type="submit" class="btn-submit">Envoyer le message</button>
      </form>

      <!-- Message de confirmation -->
      <div class="confirmation" id="confirmation" aria-live="polite" hidden>
        <span class="icon">✅</span>
        <p>Merci, votre message a bien été envoyé ! Je vous réponds sous 48h.</p>
      </div>
    </div>

  </section>

</Layout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const confirmation = document.getElementById("confirmation") as HTMLDivElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const response = await fetch(form.action, {
      method: "POST",
      body: data,
      headers: { Accept: "application/json" },
    });
    if (response.ok) {
      form.hidden = true;
      confirmation.hidden = false;
    }
  });
</script>

<style>
  .contact-hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .contact-hero h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: #6b7280;
    font-size: 1.1rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 3rem;
    align-items: start;
  }

  /* Infos */
  .contact-infos {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .info-block {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .info-block .icon {
    font-size: 1.5rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .info-block strong {
    display: block;
    font-size: 0.9rem;
    color: #111;
    margin-bottom: 0.2rem;
  }

  .info-block p {
    margin: 0;
    font-size: 0.875rem;
    color: #6b7280;
    line-height: 1.5;
  }

  /* Formulaire */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  label {
    font-size: 0.9rem;
    font-weight: 500;
    color: #374151;
  }

  .optional {
    font-weight: 400;
    color: #9ca3af;
    font-size: 0.8rem;
  }

  input, textarea {
    padding: 0.65rem 0.9rem;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 0.95rem;
    font-family: inherit;
    color: #111;
    background: #fff;
    transition: border-color 0.2s;
  }

  input:focus, textarea:focus {
    outline: none;
    border-color: #111;
  }

  textarea {
    resize: vertical;
    min-height: 120px;
  }

  .btn-submit {
    padding: 0.75rem 1.5rem;
    background: #111;
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s;
    align-self: flex-start;
  }

  .btn-submit:hover {
    background: #374151;
  }

  /* Confirmation */
  .confirmation {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 8px;
    padding: 1.25rem;
    color: #166534;
  }

  .confirmation .icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .confirmation p {
    margin: 0;
    font-size: 0.95rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .contact-infos {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .info-block {
      flex: 1 1 45%;
    }
  }
</style>
