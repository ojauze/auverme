---
import ImageMod from "@/components/ImageMod.astro";
import Logo from "@/layouts/components/Logo.astro";
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import CallToAction from "@/partials/CallToAction.astro";
import Testimonial from "@/partials/Testimonial.astro";
import UpcomingEvents from "@/partials/UpcomingEvents.astro";
import { FaCheck } from "react-icons/fa";


const homepage = await getListPage("homepage", "-index");
const call_to_action = await getListPage("ctaSection", "call-to-action");
const testimonial = await getListPage("testimonialSection", "testimonial");

const { banner, features } = homepage.data;
---

<Base
  meta_title="Orthopédagogue à Royat — Anne Jauze | Auver'me Orthopédagogie"
  description="Orthopédagogue à Royat et en visioconférence. Accompagnement des troubles dys, haut potentiel, difficultés d'apprentissage — enfants, adolescents, adultes."
>
  <!-- Banner -->
  <section class="section pt-14">
    <div class="container">
      <div class="row justify-center">
        <div class="lg:col-8 md:col-10 mb-8 text-center">

          <!-- Logo -->
          <div class="flex justify-center mb-6">
            <Logo />
          </div>

          <!-- Badge modalités — pill clair -->
          {banner.modalities.length > 0 && (
            <div class="flex justify-center mb-8">
              <div class="inline-flex items-center gap-4 rounded-full border border-border dark:border-darkmode-border bg-body dark:bg-darkmode-body px-6 py-2.5 shadow-sm">
                {banner.modalities.map((m, i) => (
                  <>
                    {i > 0 && <div class="w-px h-4 bg-border dark:bg-darkmode-border flex-shrink-0"></div>}
                    <span class="text-sm font-medium text-text dark:text-darkmode-text">{m}</span>
                  </>
                ))}
              </div>
            </div>
          )}

          <!-- Titre principal -->
          <h1 class="mb-8">{banner.title}</h1>

          <!-- Chips thématiques -->
          {banner.chips.length > 0 && (
            <div class="flex flex-wrap justify-center gap-3 mb-8">
              {banner.chips.map((tag) => (
                <span class="rounded-full border border-border dark:border-darkmode-border bg-body dark:bg-darkmode-body px-4 py-2 text-sm text-text dark:text-darkmode-text shadow-sm">
                  {tag}
                </span>
              ))}
            </div>
          )}

          <!-- Description -->
          {banner.description && (
            <p class="mb-8 text-lg text-text-light dark:text-darkmode-text-light max-w-3xl mx-auto leading-relaxed">
              {banner.description}
            </p>
          )}

          <!-- CTA -->
          {banner.button.enable && (
            <a
              class="btn btn-primary px-10 py-4 text-base rounded-xl"
              href={banner.button.link}
              target={banner.button.link.startsWith("http") ? "_blank" : "_self"}
              rel="noopener"
            >
              {banner.button.label}
            </a>
          )}
        </div>
        {banner.image && (
          <div class="col-12">
            <ImageMod
              src={banner.image}
              height={380}
              width={1200}
              alt="banner"
              format="webp"
            />
          </div>
        )}
      </div>
    </div>
  </section>
  <!-- /Banner -->

  <!-- Features — split at index 2 to insert events section -->
  {
    features.slice(0, 2).map((feature, index: number) => (
      <section class={`section-sm ${index % 2 === 0 && "bg-gradient"}`}>
        <div class="container">
          <div class="row items-center justify-between">
            <div
              class={`mb:md-0 mb-6 ${index === 0 ? "md:col-4" : "md:col-5"} ${index % 2 !== 0 && "md:order-2"}`}
            >
              <ImageMod
                src={feature.image}
                height={480}
                width={520}
                alt={feature.title}
                format="webp"
              />
            </div>
            <div class={`${index === 0 ? "md:col-8" : "md:col-7 lg:col-6"} ${index % 2 !== 0 && "md:order-1"}`}>
              <h2 set:html={markdownify(feature.title)} class="mb-4" />
              <p set:html={markdownify(feature.content)} class="mb-8 text-lg" />
              <ul>
                {feature.bulletpoints.map((bullet: string) => (
                  <li class="relative mb-4 pl-6">
                    <FaCheck className={"absolute left-0 top-1.5"} />
                    <span set:html={markdownify(bullet.text)} />
                  </li>
                ))}
              </ul>
              {feature.button.enable && (
                <a class="btn btn-primary mt-5" href={feature.button.link}>
                  {feature.button.label}
                </a>
              )}
            </div>
          </div>
        </div>
      </section>
    ))
  }
  <!-- /Features (first two) -->

  <!-- Upcoming events section -->
  <UpcomingEvents />

  <!-- Features — remaining (from index 2) -->
  {
    features.slice(2).map((feature, index: number) => (
      <section class={`section-sm ${(index + 2) % 2 === 0 && "bg-gradient"}`}>
        <div class="container">
          <div class="row items-center justify-between">
            <div
              class={`mb:md-0 mb-6 md:col-5 ${(index + 2) % 2 !== 0 && "md:order-2"}`}
            >
              <ImageMod
                src={feature.image}
                height={480}
                width={520}
                alt={feature.title}
                format="webp"
              />
            </div>
            <div class={`md:col-7 lg:col-6 ${(index + 2) % 2 !== 0 && "md:order-1"}`}>
              <h2 set:html={markdownify(feature.title)} class="mb-4" />
              <p set:html={markdownify(feature.content)} class="mb-8 text-lg" />
              <ul>
                {feature.bulletpoints.map((bullet: string) => (
                  <li class="relative mb-4 pl-6">
                    <FaCheck className={"absolute left-0 top-1.5"} />
                    <span set:html={markdownify(bullet.text)} />
                  </li>
                ))}
              </ul>
              {feature.button.enable && (
                <a class="btn btn-primary mt-5" href={feature.button.link}>
                  {feature.button.label}
                </a>
              )}
            </div>
          </div>
        </div>
      </section>
    ))
  }
  <!-- /Features (remaining) -->

  <!-- Tarifs -->
  <section class="section-sm bg-gradient">
    <div class="container">
      <div class="row justify-center text-center mb-10">
        <div class="lg:col-6">
          <h2 class="mb-4">Tarifs</h2>
          <p class="text-text-light dark:text-darkmode-text-light">Séances individuelles sans engagement, forfaits disponibles.</p>
        </div>
      </div>

      <div class="row gy-4 justify-center">
        <!-- Séances unitaires -->
        <div class="md:col-5 lg:col-4">
          <div class="rounded-xl border border-border bg-body p-8 text-center shadow-sm dark:border-darkmode-border dark:bg-darkmode-body h-full flex flex-col gap-4">
            <h3 class="h4">Séance individuelle</h3>
            <div class="flex justify-center gap-8">
              <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-text-light dark:text-darkmode-text-light mb-1">Enfants</p>
                <p class="text-4xl font-bold text-primary">45 €</p>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-text-light dark:text-darkmode-text-light mb-1">Adultes</p>
                <p class="text-4xl font-bold text-primary">55 €</p>
              </div>
            </div>
            <p class="text-sm text-text-light dark:text-darkmode-text-light mt-auto">Sans engagement</p>
          </div>
        </div>

        <!-- Forfait 10 séances -->
        <div class="md:col-5 lg:col-4">
          <div class="rounded-xl border-2 border-primary bg-body p-8 text-center shadow-md dark:bg-darkmode-body h-full flex flex-col gap-4 relative overflow-hidden">
            <span class="absolute top-4 right-4 rounded-full bg-primary px-3 py-0.5 text-xs font-semibold text-white">Forfait</span>
            <h3 class="h4">10 séances</h3>
            <div class="flex justify-center gap-8">
              <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-text-light dark:text-darkmode-text-light mb-1">Enfant</p>
                <p class="text-4xl font-bold text-primary">400 €</p>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-text-light dark:text-darkmode-text-light mb-1">Adulte</p>
                <p class="text-4xl font-bold text-primary">500 €</p>
              </div>
            </div>
            <p class="text-sm text-text-light dark:text-darkmode-text-light mt-auto">Économisez 50 € · Engagement sur 10 séances</p>
          </div>
        </div>

        <!-- Offre sur mesure -->
        <div class="md:col-10 lg:col-8">
          <div class="rounded-xl bg-light dark:bg-darkmode-light p-6 flex items-center gap-4 text-sm text-text dark:text-darkmode-text">
            <span class="text-2xl flex-shrink-0">📋</span>
            <p><strong>Offre sur mesure</strong> disponible pour les accompagnements intensifiés ou les médiations scolaires. <a href="/contact" class="text-primary underline underline-offset-2">Contactez-moi</a> pour un devis personnalisé.</p>
          </div>
        </div>
      </div>

      <!-- Note crédit d'impôt -->
      <div class="row justify-center mt-6">
        <div class="lg:col-8 md:col-10 text-center">
          <p class="text-sm text-text-light dark:text-darkmode-text-light">
            💡 <strong>Crédit d'impôt 50 %</strong> applicable via le dispositif CESU — le coût réel est divisé par deux pour les foyers imposables.
          </p>
        </div>
      </div>
    </div>
  </section>
  <!-- /Tarifs -->

  <Testimonial testimonial={testimonial} />
  <CallToAction call_to_action={call_to_action} />
</Base>
