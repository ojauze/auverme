---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";
import Container from "../components/Container.astro";
import Button from "../components/Button.astro";
import { siteConfig } from "../data/config";

const allArticles = await getCollection("actualites", ({ data }) => !data.draft);
const articles = allArticles.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

function formatDate(date: Date) {
  return date.toLocaleDateString("fr-FR", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<Layout
  title="Actualités"
  description={`Articles et ressources sur l'orthopédagogie, les troubles dys, le haut potentiel — par ${siteConfig.shortName}.`}
>

  <!-- ══ HERO ══════════════════════════════════════════════════════ -->
  <Section bg="default" spacing="lg">
    <Container size="md">
      <div class="page-hero">
        <p class="page-eyebrow">Actualités &amp; ressources</p>
        <h1 class="page-title">Le blog</h1>
        <p class="page-subtitle">
          Articles, conseils et ressources sur l'orthopédagogie, les troubles
          dys, le haut potentiel et tout ce qui touche aux apprentissages.
        </p>
      </div>
    </Container>
  </Section>

  <!-- ══ ARTICLES ═══════════════════════════════════════════════════ -->
  <Section bg="alt" spacing="lg">
    <Container size="lg">
      {articles.length === 0 ? (
        <div class="empty-state">
          <p>Aucun article publié pour l'instant. Revenez bientôt !</p>
          <Button href="/" variant="outline">Retour à l'accueil</Button>
        </div>
      ) : (
        <ul class="articles-grid" role="list">
          {articles.map(article => (
            <li>
              <a href={`/actualites/${article.slug}`} class="article-card">
                <div class="article-meta">
                  <time datetime={article.data.date.toISOString()}>
                    {formatDate(article.data.date)}
                  </time>
                  {article.data.tags.slice(0, 2).map(tag => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
                <h2 class="article-title">{article.data.title}</h2>
                <p class="article-desc">{article.data.description}</p>
                <span class="article-cta">Lire l'article →</span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </Container>
  </Section>

  <!-- ══ CTA ════════════════════════════════════════════════════════ -->
  <Section bg="dark" spacing="md">
    <Container size="sm">
      <div class="newsletter-cta">
        <h2 class="cta-title">Une question spécifique ?</h2>
        <p class="cta-sub">Je préfère les échanges directs aux newsletters. Écrivez-moi.</p>
        <Button href="/contact" variant="primary">Me contacter</Button>
      </div>
    </Container>
  </Section>

</Layout>

<style>
  .page-hero { text-align: center; }

  .page-eyebrow {
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-brand-600);
    margin: 0 0 1rem;
  }

  .page-title {
    font-family: var(--font-display, 'Fredoka', sans-serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 600;
    margin: 0 0 1.25rem;
    color: var(--color-warm-900);
  }

  .page-subtitle {
    font-size: 1.1rem;
    color: var(--color-warm-600);
    max-width: 52ch;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ── Grid articles ────────────────────────────────────────────── */
  .articles-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .article-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: #fff;
    border-radius: var(--radius-card, 1rem);
    padding: 1.75rem;
    box-shadow: var(--shadow-card);
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .article-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 28px rgba(0,0,0,0.1);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.875rem;
  }

  .article-meta time {
    font-size: 0.8rem;
    color: var(--color-warm-500);
  }

  .tag {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    background: var(--color-brand-100);
    color: var(--color-brand-700);
    border-radius: 9999px;
  }

  .article-title {
    font-family: var(--font-display, 'Fredoka', sans-serif);
    font-size: 1.2rem;
    font-weight: 600;
    margin: 0 0 0.6rem;
    color: var(--color-warm-900);
    line-height: 1.3;
    flex-grow: 0;
  }

  .article-desc {
    font-size: 0.9rem;
    color: var(--color-warm-600);
    line-height: 1.6;
    margin: 0 0 1.25rem;
    flex-grow: 1;
  }

  .article-cta {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-brand-600);
    margin-top: auto;
  }

  .article-card:hover .article-cta {
    color: var(--color-brand-700);
  }

  /* ── Empty state ──────────────────────────────────────────────── */
  .empty-state {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding: 3rem 0;
    color: var(--color-warm-500);
  }

  /* ── CTA final ────────────────────────────────────────────────── */
  .newsletter-cta {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .cta-title {
    font-family: var(--font-display, 'Fredoka', sans-serif);
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-brand-200);
    margin: 0;
  }

  .cta-sub {
    color: var(--color-warm-400);
    margin: 0;
  }
</style>
