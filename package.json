{
  "name": "auverme",
  "version": "1.0.0",
  "description": "Site Auverme Orthopédagogie",
  "author": "Auverme",
  "license": "MIT",
  "packageManager": "yarn@1.22.22",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node scripts/themeGenerator.js --watch\" \"node scripts/jsonGenerator.js && astro dev\"",
    "build": "node scripts/themeGenerator.js && node scripts/jsonGenerator.js && astro build && node scripts/llmsGenerator.js",
    "preview": "astro preview",
    "check": "astro check",
    "format": "prettier -w ./src",
    "generate-json": "node scripts/jsonGenerator.js",
    "generate-llms": "node scripts/llmsGenerator.js",
    "remove-darkmode": "node scripts/removeDarkmode.js && yarn format",
    "deploy:cf-workers": "npm run build && wrangler deploy",
    "preview:cf-workers": "npm run build && wrangler dev"
  },
  "dependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/mdx": "5.0.3",
    "@astrojs/node": "^10.0.6",
    "@astrojs/react": "5.0.3",
    "@astrojs/sitemap": "3.7.2",
    "@keystatic/astro": "^5.1.0",
    "@keystatic/core": "^0.5.50",
    "@schedule-x/calendar": "^4.6.0",
    "@schedule-x/react": "^4.1.0",
    "@schedule-x/theme-default": "^4.6.0",
    "astro": "6.1.9",
    "astro-auto-import": "^0.5.1",
    "astro-swiper": "^2.5.0",
    "date-fns": "^4.1.0",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "marked": "^17.0.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "sharp": "^0.34.5",
    "vite": "^7.1.5"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "glob": "^13.0.6",
    "node-html-parser": "^7.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwind-bootstrap-grid": "^7.0.0",
    "tailwindcss": "^4.2.2",
    "turndown": "^7.2.4",
    "typescript": "^6.0.2",
    "wrangler": "^4.80.0"
  },
  "overrides": {
    "typescript": "$typescript",
    "astro": "$astro"
  }
}
